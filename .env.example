# 서버 설정
PORT=4000

# 프론트엔드 URL (CORS 허용 도메인)
FRONTEND_URL=http://localhost:3000

# PostgreSQL DB 설정
DB_HOST=localhost
DB_PORT=5432
DB_NAME=physics_qna
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT 비밀키 (길고 복잡하게 설정하세요)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long

# 추천 코드 (학생 가입용)
INVITE_CODE=your_invite_code_here

# 관리자 계정 초기 설정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here
